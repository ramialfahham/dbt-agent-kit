{
  "_comment": "All hooks fail open (a hook bug never blocks work) and self-gate on the real command. Paths use ${CLAUDE_PLUGIN_ROOT} so they resolve wherever the plugin is installed.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/handover_in.py\"",
            "statusMessage": "Loading active-work handover..."
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/commit_review_gate.py\" \"${CLAUDE_PLUGIN_ROOT}\"",
            "statusMessage": "Review gate: checking the change was reviewed..."
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/pre_push_gate.py\"",
            "statusMessage": "Pre-push checklist..."
          },
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/handover_out.py\"",
            "statusMessage": "Handover write-out reminder..."
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/handover_plan_gate.py\"",
            "statusMessage": "Plan-back gate..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/hooks/plan_implement_gate.py\"",
            "statusMessage": "Plan to implementation checklist..."
          }
        ]
      }
    ]
  }
}
